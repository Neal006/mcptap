{
  "name": "mcptap",
  "version": "0.1.0",
  "description": "See what your AI agent is actually doing. Passive traffic capture, token cost attribution, and replay for MCP servers — one command.",
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "observability",
    "debugging",
    "proxy",
    "ai-agents",
    "claude",
    "cursor",
    "developer-tools"
  ],
  "homepage": "https://github.com/Neal006/mcptap",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neal006/mcptap.git"
  },
  "bugs": "https://github.com/Neal006/mcptap/issues",
  "license": "MIT",
  "author": "Neal006",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mcptap": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "check": "biome check . && tsc --noEmit && vitest run --passWithNoTests",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run check"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^26.1.0",
    "simple-git-hooks": "^2.13.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "cross-spawn": "^7.0.6"
  }
}
